# tinyowl 前端 + nginx 镜像
# 阶段一：vite 构建前端静态产物
# 阶段二：nginx 托管静态文件并反代后端 API

# ---------- builder ----------
FROM node:22-bookworm AS builder

RUN corepack enable && corepack prepare pnpm@10.33.4 --activate
WORKDIR /app

COPY pnpm-workspace.yaml package.json pnpm-lock.yaml tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/frontend/package.json packages/frontend/

RUN pnpm install --frozen-lockfile --filter @tinyowl/shared... --filter @tinyowl/frontend...

# 前端通过 vite 解析 @tinyowl/shared 的源码类型，需要 shared 源码
COPY packages/shared packages/shared
COPY packages/frontend packages/frontend
RUN pnpm --filter @tinyowl/frontend build

# ---------- runtime ----------
FROM nginx:1.27-alpine AS runtime

# 前端静态产物
COPY --from=builder /app/packages/frontend/dist /usr/share/nginx/html
# nginx 站点配置（证书与后端反代在 conf 中）
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80 443
